Date: Mon, 13 Jul 2026 10:16:06 +0900
Subject: [PATCH] Replace orbital visual with DNA sequence scanner

---
 assets/css/main.css               | 291 ++++++++++++++++++++++++++++--
 layouts/index.html                |  61 ++++---
 layouts/partials/sector-page.html |  18 +-
 3 files changed, 321 insertions(+), 49 deletions(-)

diff --git a/assets/css/main.css b/assets/css/main.css
index dbffee8..2eacba3 100644
--- a/assets/css/main.css
+++ b/assets/css/main.css
@@ -533,6 +533,268 @@ h2 em {
 .stage-card-index { color: var(--orange); font-size: 1.6rem; font-weight: 700; letter-spacing: -0.08em; }
 .stage-caption { position: absolute; right: 1.4rem; bottom: 1.25rem; color: rgba(255, 255, 255, 0.46); }
 
+/* Genetic sequence scanner */
+.sequence-display {
+  position: relative;
+  display: grid;
+  min-height: clamp(28rem, 52vw, 42rem);
+  grid-template-rows: auto 1fr auto;
+  overflow: hidden;
+  border: 1px solid rgba(255, 255, 255, 0.78);
+  border-radius: 2rem;
+  background:
+    radial-gradient(circle at 85% 8%, rgba(233, 155, 115, 0.15), transparent 15rem),
+    linear-gradient(145deg, rgba(255, 255, 255, 0.96), rgba(235, 240, 235, 0.88));
+  box-shadow: 0 2rem 5rem rgba(7, 25, 35, 0.1), inset 0 1px rgba(255, 255, 255, 0.9);
+  color: var(--ink);
+}
+
+.sequence-display::before {
+  position: absolute;
+  top: 0;
+  right: 2.3rem;
+  bottom: 0;
+  width: 1px;
+  background: linear-gradient(transparent, rgba(217, 65, 63, 0.2), transparent);
+  content: "";
+}
+
+.sequence-display__header,
+.sequence-display__footer {
+  position: relative;
+  z-index: 2;
+  display: flex;
+  align-items: center;
+  justify-content: space-between;
+  gap: 1rem;
+  padding: 1.35rem 1.5rem;
+}
+
+.sequence-display__header {
+  border-bottom: 1px solid var(--line);
+}
+
+.sequence-display__footer {
+  border-top: 1px solid var(--line);
+  color: var(--muted);
+  font-size: 0.62rem;
+  font-weight: 700;
+  letter-spacing: 0.1em;
+  text-transform: uppercase;
+}
+
+.sequence-status,
+.sequence-display__legend,
+.sequence-display__footer span {
+  display: inline-flex;
+  align-items: center;
+  gap: 0.45rem;
+}
+
+.sequence-status {
+  color: var(--muted);
+  font-size: 0.65rem;
+  font-weight: 700;
+  letter-spacing: 0.12em;
+  text-transform: uppercase;
+}
+
+.sequence-status i,
+.motif-key {
+  display: inline-block;
+  width: 0.45rem;
+  height: 0.45rem;
+  border-radius: 50%;
+  background: #d9413f;
+  box-shadow: 0 0 0 0.25rem rgba(217, 65, 63, 0.12);
+}
+
+.sequence-display__legend {
+  gap: 0.35rem;
+  color: var(--muted);
+  font-family: ui-monospace, SFMono-Regular, Consolas, monospace;
+  font-size: 0.7rem;
+}
+
+.sequence-display__legend b {
+  display: inline-grid;
+  width: 1.25rem;
+  height: 1.25rem;
+  place-items: center;
+  border: 1px solid var(--line);
+  border-radius: 0.3rem;
+  background: rgba(255, 255, 255, 0.55);
+  color: var(--ink-soft);
+  font-weight: 600;
+}
+
+.sequence-display__body {
+  position: relative;
+  display: grid;
+  grid-template-columns: 2.75rem 1fr;
+  min-height: 0;
+  padding: 1.1rem 1.5rem 1.1rem 1.1rem;
+}
+
+.sequence-axis {
+  display: flex;
+  flex-direction: column;
+  justify-content: space-between;
+  padding: 0.2rem 0.55rem 0.25rem 0;
+  color: rgba(7, 25, 35, 0.35);
+  font-family: ui-monospace, SFMono-Regular, Consolas, monospace;
+  font-size: 0.72rem;
+}
+
+.sequence-window {
+  position: relative;
+  min-height: 0;
+  overflow: hidden;
+  border-left: 1px solid rgba(7, 25, 35, 0.16);
+}
+
+.sequence-window::before,
+.sequence-window::after {
+  position: absolute;
+  right: 0;
+  left: 0;
+  z-index: 1;
+  height: 4rem;
+  content: "";
+  pointer-events: none;
+}
+
+.sequence-window::before {
+  top: 0;
+  background: linear-gradient(to bottom, rgba(239, 243, 238, 0.98), transparent);
+}
+
+.sequence-window::after {
+  bottom: 0;
+  background: linear-gradient(to top, rgba(239, 243, 238, 0.98), transparent);
+}
+
+.sequence-track {
+  display: grid;
+  animation: sequence-scroll 28s linear infinite;
+  will-change: transform;
+}
+
+.sequence-row {
+  display: grid;
+  grid-template-columns: 3.2rem 1fr;
+  min-height: 2.25rem;
+  align-items: center;
+  border-bottom: 1px solid rgba(7, 25, 35, 0.06);
+}
+
+.sequence-row__index {
+  color: rgba(7, 25, 35, 0.32);
+  font-family: ui-monospace, SFMono-Regular, Consolas, monospace;
+  font-size: 0.62rem;
+  letter-spacing: 0.04em;
+}
+
+.sequence-string {
+  overflow: hidden;
+  color: rgba(7, 25, 35, 0.86);
+  font-family: ui-monospace, SFMono-Regular, Consolas, monospace;
+  font-size: clamp(0.83rem, 1.35vw, 1.2rem);
+  letter-spacing: clamp(0.06em, 0.45vw, 0.18em);
+  line-height: 1;
+  white-space: nowrap;
+}
+
+.sequence-string .motif,
+.sector-code-sequence b {
+  color: #d9413f;
+  font-weight: 700;
+}
+
+.sequence-display__footer .motif-key {
+  width: 0.38rem;
+  height: 0.38rem;
+  box-shadow: none;
+}
+
+.sector-scan-header {
+  position: relative;
+  z-index: 2;
+  display: flex;
+  justify-content: space-between;
+  padding: 1.3rem 1.5rem;
+  border-bottom: 1px solid rgba(255, 255, 255, 0.16);
+  color: rgba(255, 255, 255, 0.55);
+  font-family: ui-monospace, SFMono-Regular, Consolas, monospace;
+  font-size: 0.66rem;
+  letter-spacing: 0.08em;
+  text-transform: uppercase;
+}
+
+.sector-code-panel {
+  position: absolute;
+  top: 50%;
+  left: 50%;
+  z-index: 2;
+  display: grid;
+  gap: 0.75rem;
+  width: min(80%, 22rem);
+  padding: 1.5rem;
+  border: 1px solid rgba(255, 255, 255, 0.24);
+  border-radius: 1rem;
+  background: rgba(7, 25, 35, 0.74);
+  box-shadow: 0 1.5rem 3rem rgba(0, 0, 0, 0.16);
+  color: var(--white);
+  transform: translate(-50%, -50%);
+  -webkit-backdrop-filter: blur(12px);
+  backdrop-filter: blur(12px);
+}
+
+.sector-code-label {
+  color: var(--mint);
+  font-size: 0.62rem;
+  font-weight: 700;
+  letter-spacing: 0.11em;
+  text-transform: uppercase;
+}
+
+.sector-code-panel strong {
+  color: var(--accent);
+  font-size: clamp(2.8rem, 6vw, 5.2rem);
+  letter-spacing: -0.08em;
+  line-height: 0.8;
+}
+
+.sector-code-sequence {
+  color: rgba(255, 255, 255, 0.68);
+  font-family: ui-monospace, SFMono-Regular, Consolas, monospace;
+  font-size: 0.72rem;
+  letter-spacing: 0.08em;
+  white-space: nowrap;
+}
+
+.sector-scan-lines {
+  position: absolute;
+  right: 1.5rem;
+  bottom: 1.6rem;
+  left: 1.5rem;
+  z-index: 1;
+  display: grid;
+  gap: 0.8rem;
+}
+
+.sector-scan-lines i {
+  display: block;
+  height: 1px;
+  background: linear-gradient(to right, transparent, color-mix(in srgb, var(--accent), white 20%), transparent);
+  opacity: 0.55;
+}
+
+.sector-scan-lines i:nth-child(2) { width: 78%; }
+.sector-scan-lines i:nth-child(3) { width: 92%; margin-left: 8%; }
+.sector-scan-lines i:nth-child(4) { width: 62%; }
+.sector-scan-lines i:nth-child(5) { width: 84%; margin-left: 16%; }
+
 .section {
   padding-block: clamp(5rem, 10vw, 10rem);
 }
@@ -840,9 +1102,7 @@ h2 em {
 .footer-note a { font-size: 0.85rem; font-weight: 700; text-decoration: none; }
 .footer-meta { display: grid; gap: 0.35rem; color: var(--muted); font-size: 0.68rem; text-align: right; text-transform: uppercase; letter-spacing: 0.08em; }
 
-@keyframes spin-one { to { transform: rotate(384deg) scaleY(0.42); } }
-@keyframes spin-two { to { transform: rotate(308deg) scaleY(0.58); } }
-@keyframes spin-three { to { transform: rotate(448deg) scaleY(0.8); } }
+@keyframes sequence-scroll { to { transform: translateY(-50%); } }
 
 @media (prefers-reduced-motion: reduce) {
   html { scroll-behavior: auto; }
@@ -854,7 +1114,7 @@ h2 em {
   .sector-hero { grid-template-columns: 1fr; }
   .hero-shell { min-height: auto; padding-top: 6rem; }
   .hero-copy h1 { max-width: 9ch; }
-  .hero-stage { width: min(100%, 40rem); min-height: 32rem; margin-inline: auto; }
+  .sequence-display { width: min(100%, 40rem); min-height: 32rem; margin-inline: auto; }
   .sector-hero { min-height: auto; padding-top: 6rem; }
   .sector-hero-copy h1 { max-width: 11ch; }
   .sector-visual { width: min(100%, 40rem); min-height: 31rem; margin-inline: auto; }
@@ -881,16 +1141,14 @@ h2 em {
   .hero-shell { padding-top: 5rem; }
   .hero-copy h1 { font-size: clamp(3.8rem, 18vw, 6.6rem); }
   .hero-lede { font-size: 1rem; }
-  .hero-stage { min-height: 25rem; border-radius: 1.4rem; }
-  .orbit-system { width: 85%; }
-  .orbit-core { width: 7rem; height: 7rem; }
-  .orbit-core strong { font-size: 1.25rem; }
-  .stage-card { min-width: 8rem; padding: 0.65rem; }
-  .stage-card-top { top: 7%; left: 5%; }
-  .stage-card-bottom { right: 5%; bottom: 7%; }
-  .stage-card strong { font-size: 0.75rem; }
-  .stage-card > span:last-child { font-size: 0.58rem; }
-  .stage-caption { right: 1rem; bottom: 0.85rem; font-size: 0.52rem; }
+  .sequence-display { min-height: 25rem; border-radius: 1.4rem; }
+  .sequence-display__header,
+  .sequence-display__footer { padding: 1rem; }
+  .sequence-display__body { grid-template-columns: 2rem 1fr; padding: 0.8rem 0.85rem 0.8rem 0.7rem; }
+  .sequence-row { grid-template-columns: 2.6rem 1fr; }
+  .sequence-row__index { font-size: 0.5rem; }
+  .sequence-string { font-size: 0.72rem; letter-spacing: 0.04em; }
+  .sequence-display__footer { font-size: 0.52rem; }
   .section-heading,
   .section-heading-wide { grid-template-columns: 1fr; gap: 1.2rem; margin-bottom: 2rem; }
   .section-heading h2,
@@ -909,9 +1167,8 @@ h2 em {
   .sector-hero-copy h1 { font-size: clamp(3.4rem, 15vw, 5.8rem); }
   .back-link { margin-bottom: 3rem; }
   .sector-visual { min-height: 24rem; border-radius: 1.4rem; }
-  .sector-orbit { width: 88%; }
-  .sector-core { width: 6.8rem; height: 6.8rem; }
-  .sector-core strong { font-size: 1.2rem; }
+  .sector-code-panel { width: 82%; padding: 1.2rem; }
+  .sector-code-sequence { font-size: 0.62rem; letter-spacing: 0.04em; }
   .visual-label { font-size: 0.56rem; }
   .footer-grid { grid-template-columns: 1fr; gap: 1.5rem; }
   .footer-meta { text-align: left; }
